# Sensitive local Codex exporter archive root.
CODEX_SESSION_RAW_DATA_PATH=

# Neo4j Bolt connection.
NEO4J_CONNECTION_URL=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
HARNESS_GRAPH_NAMESPACE=default
HARNESS_GRAPH_BATCH_SIZE=250

# Mistral is the only supported foundation-model provider.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_CONCURRENCY=2

# Additive transcript enrichment is disabled and privacy-blocked by default.
# The HMAC key must be a distinct 32-byte-or-longer secret; never reuse the
# Mistral API key. Store it in 1Password and inject it at runtime.
HARNESS_GRAPH_TRANSCRIPT_ENRICHMENT_MODE=disabled
HARNESS_GRAPH_MISTRAL_PRIVACY_CONTROL=unverified
HARNESS_GRAPH_REDACTION_HMAC_KEY=
MISTRAL_TRANSCRIPT_MODEL=mistral-small-2603

# Mistral Small 4 regional-EU rates expressed as micro-USD per million tokens.
# Reconfirm these values against Mistral's pricing before a paid backfill.
HARNESS_GRAPH_TRANSCRIPT_INPUT_MICROUSD_PER_MILLION_TOKENS=165000
HARNESS_GRAPH_TRANSCRIPT_OUTPUT_MICROUSD_PER_MILLION_TOKENS=660000
HARNESS_GRAPH_TRANSCRIPT_ESTIMATED_OUTPUT_TOKENS_PER_REQUEST=1024

# HTTP listener for the API and visualization.
HARNESS_GRAPH_BIND_ADDRESS=127.0.0.1:3000
HARNESS_GRAPH_JOURNAL_PATH=data/live-events.jsonl
