# Sensitive local Codex exporter archive root.
CODEX_SESSION_RAW_DATA_PATH=

# Neo4j Bolt connection. Repository-file canonical values (or retained typo
# aliases) take precedence over unrelated inherited process credentials.
NEO4J_CONNECTION_URL=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
HARNESS_GRAPH_NAMESPACE=default
HARNESS_GRAPH_BATCH_SIZE=250

# Mistral is the only supported foundation-model provider. Transcript apply
# requires this exact canonical name in the repository-root .env; an inherited
# process value or MISTARL_API_KEY alias cannot select another account.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_CONCURRENCY=2

# Additive transcript enrichment is disabled and privacy-blocked by default.
# Set training_opt_out_verified only after an operator confirms the Mistral
# account's API training/data-sharing control is disabled.
HARNESS_GRAPH_TRANSCRIPT_ENRICHMENT_MODE=disabled
HARNESS_GRAPH_MISTRAL_PRIVACY_CONTROL=unverified

# This must be one stable, dedicated secret of at least 32 bytes and must differ
# from every provider/database credential. Prefer leaving it out of .env: store
# it in 1Password and inject it with `op run` as documented in README.md.
HARNESS_GRAPH_REDACTION_HMAC_KEY=

# Cost-bearing transcript extraction is pinned to mistral-small-2603 on
# https://api.eu.mistral.ai and rejects any other configured model.
MISTRAL_TRANSCRIPT_MODEL=mistral-small-2603

# Regional-EU estimation snapshot: $0.165/M input and $0.66/M output, expressed
# as micro-USD per million tokens. Reconfirm pricing before a paid backfill.
HARNESS_GRAPH_TRANSCRIPT_INPUT_MICROUSD_PER_MILLION_TOKENS=165000
HARNESS_GRAPH_TRANSCRIPT_OUTPUT_MICROUSD_PER_MILLION_TOKENS=660000
HARNESS_GRAPH_TRANSCRIPT_ESTIMATED_OUTPUT_TOKENS_PER_REQUEST=1024

# HTTP listener for the API and visualization.
HARNESS_GRAPH_BIND_ADDRESS=127.0.0.1:3000
HARNESS_GRAPH_JOURNAL_PATH=data/live-events.jsonl
